{
  "info": {
    "name": "TaskFlow API",
    "description": "Complete API collection for TaskFlow Real-Time Collaborative Management Tool",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Test User\", \"email\": \"test@test.com\", \"password\": \"password123\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"test@test.com\", \"password\": \"password123\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "Get All Workspaces",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/workspaces",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Workspace",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/workspaces",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"My Workspace\", \"description\": \"Test workspace\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Workspace",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/workspaces/{{workspace_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Delete Workspace",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/workspaces/{{workspace_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Boards",
      "item": [
        {
          "name": "Get Boards by Workspace",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/boards/workspace/{{workspace_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Board",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/boards",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Sprint 1\", \"workspaceId\": \"{{workspace_id}}\", \"backgroundColor\": \"#0079BF\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Board",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/boards/{{board_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Delete Board",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/boards/{{board_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Cards",
      "item": [
        {
          "name": "Create Card",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/cards",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"New Task\", \"listId\": \"{{list_id}}\", \"priority\": \"medium\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Card",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/cards/{{card_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Card",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/cards/{{card_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Updated Task\", \"priority\": \"high\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Move Card",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/cards/{{card_id}}/move",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\"listId\": \"{{list_id}}\", \"position\": 0}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Card",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/cards/{{card_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/cards/{{card_id}}/comments",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\"content\": \"This is a comment\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Add Checklist Item",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/cards/{{card_id}}/checklist",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Checklist item\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token", "value": "YOUR_JWT_TOKEN" },
    { "key": "workspace_id", "value": "YOUR_WORKSPACE_ID" },
    { "key": "board_id", "value": "YOUR_BOARD_ID" },
    { "key": "list_id", "value": "YOUR_LIST_ID" },
    { "key": "card_id", "value": "YOUR_CARD_ID" }
  ]
}
