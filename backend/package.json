{
  "name": "taskflow-backend",
  "version": "1.0.0",
  "description": "Real Time Collaborative Management Tool - Backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
